# Required: Your Google account email address
GOOGLE_EMAIL=your-email@gmail.com

# Required: Your Google master token
# To obtain: see README.md "Getting a Master Token" section
GOOGLE_MASTER_TOKEN=aas_et/...

# Optional: Path to a JSON cache file for faster startup
# KEEP_CACHE_FILE=~/.cache/google-keep-mcp/state.json

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO
